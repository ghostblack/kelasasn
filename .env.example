# ============================================================
# Environment Variables — KelasASN
# Salin file ini ke .env dan isi nilainya
# ============================================================

# ─── Telegram Notifications ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── TriPay via Google Apps Script ──────────────────────────
# 1. Buka https://script.google.com → New Project
# 2. Paste isi file google-apps-script/TripayProxy.gs
# 3. Jalankan fungsi setupScriptProperties (Run menu)
# 4. Deploy → New Deployment → Web App
#    - Execute as: Me
#    - Who has access: Anyone
# 5. Copy URL deployment dan isi di bawah
VITE_TRIPAY_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# ─── Netlify Environment Variables (set di Netlify Dashboard) ─
# Buka: Site Settings → Environment Variables
#
# TRIPAY_ENVIRONMENT=sandbox          # atau "production"
# TRIPAY_PRIVATE_KEY_SANDBOX=KDo45-rfo1e-eVdb9-uM9LU-rGm4W   # sudah tersedia
# TRIPAY_PRIVATE_KEY_PROD=            # isi saat migrasi ke production
#
# FIREBASE_SERVICE_ACCOUNT=          # JSON service account dari Firebase Console
# → Firebase Console → Project Settings → Service Accounts
# → Generate new private key → download JSON → paste seluruh isi JSON di sini
#
# TELEGRAM_BOT_TOKEN=                # sama seperti di atas
# TELEGRAM_CHAT_ID=                  # sama seperti di atas
